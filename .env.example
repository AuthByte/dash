OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
TWITTER_HANDLE=aleabitoreddit

# Supabase (optional). When set, the app reads people / picks / prices / themes / site_meta / tweet_events
# from Postgres; `pnpm refresh` upserts refreshed tickers into the `prices` table.
# Tables expected: people, picks, prices, themes, site_meta, tweet_events (see Supabase schema).
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Server + scripts only — never expose in the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=
# Alternative URL name supported by some setups:
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Which profile `npm run scrape` merges into (under data/people/<slug>/).
# SCRAPE_PERSON_SLUG=serenity

# X (Twitter) cookie session.
# Log in to x.com in any browser, open DevTools -> Application -> Cookies -> https://x.com,
# and copy the values of `auth_token` and `ct0` here.
X_AUTH_TOKEN=
X_CT0=
