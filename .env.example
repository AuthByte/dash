OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
TWITTER_HANDLE=aleabitoreddit

# Optional fallback data source for refresh.ts.
# Leave enabled for broader coverage when FMP omits history/metrics.
YFINANCE_ENABLED=1
# Optional custom python executable for yfinance fetch helper.
PYTHON_BIN=python3

# X (Twitter) cookie session.
# Log in to x.com in any browser, open DevTools -> Application -> Cookies -> https://x.com,
# and copy the values of `auth_token` and `ct0` here.
X_AUTH_TOKEN=
X_CT0=
