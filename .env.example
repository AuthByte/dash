OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
TWITTER_HANDLE=aleabitoreddit

# Optional Supabase-backed storage for app/script data.
# If these are set, the app reads from Supabase first (with file fallback),
# and refresh writes person datasets to Supabase.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# Optional table names (defaults shown):
SUPABASE_PEOPLE_TABLE=people
SUPABASE_DATA_TABLE=person_datasets

# Optional fallback data source for refresh.ts.
# Leave enabled for broader coverage when FMP omits history/metrics.
YFINANCE_ENABLED=1
# Optional custom python executable for yfinance fetch helper.
PYTHON_BIN=python3

# X (Twitter) cookie session.
# Log in to x.com in any browser, open DevTools -> Application -> Cookies -> https://x.com,
# and copy the values of `auth_token` and `ct0` here.
X_AUTH_TOKEN=
X_CT0=

# Supabase — project: dashboard
# URL + anon key for the Next.js app (used on the server only; site is fully SSG).
NEXT_PUBLIC_SUPABASE_URL=https://ffnirabafwfjaeofmber.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_wAHXSGcQiQ_05V73wTPL1A_M4r3VyXp

# Service role key — only needed by the scripts (refresh, apply_digest) to write.
# Grab from the Supabase dashboard: Project Settings -> API -> `service_role` key.
# Never commit this. The anon key above works for writes too while RLS is permissive,
# but set this up for production-safety.
SUPABASE_SERVICE_ROLE_KEY=
